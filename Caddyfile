{
    # Disable Caddy's admin API (we don't need it; reduces attack surface).
    admin off
    # Log to stdout so Fly captures it.
    # level DEBUG = highest verbosity practical (PANIC/FATAL exist but
    # are reserved for fatal-only).
    log {
        output stdout
        format console
        level DEBUG
    }
}

# Auth model (see ADR 0002 + ADR 0003):
#   - /healthz: open, no auth (Fly health checks).
#   - /.well-known/oauth-protected-resource: open, MCP Protected Resource
#     Metadata for client discovery (proxied to tokeninfo sidecar).
#   - Per-service named bearers (FRED_MCP_TOKEN_<NAME>): direct proxy to
#     toolbox with X-Service header attribution.
#   - Legacy shared FRED_MCP_TOKEN: direct proxy (transition period;
#     remove once all humans migrate to OIDC).
#   - Default: forward_auth to tokeninfo sidecar for Google OIDC
#     validation, then proxy to toolbox on success.
#
# Adding a new service consumer:
#   1. fly secrets set FRED_MCP_TOKEN_<NEW_SERVICE>=$(openssl rand -base64 32) -a fred-mcp
#   2. add a `@svc_<new_service>` matcher + handle block below.
#   3. add the env var name to entrypoint.sh's REQUIRED_VARS list.
#
# Empty-env-var trap: if a service-token env var is unset, Caddy
# substitutes empty string and the matcher becomes
# `Authorization "Bearer "` — any literal `Authorization: Bearer `
# request would match. entrypoint.sh fails-fast at startup if any
# expected token var is unset or empty.

:8080 {
    # Health check passthrough — no auth required, returns 200.
    handle /healthz {
        respond "ok" 200
    }

    # MCP Protected Resource Metadata — open, proxied to sidecar.
    # Clients use this for OAuth discovery per the MCP authorization spec.
    handle /.well-known/oauth-protected-resource {
        reverse_proxy 127.0.0.1:5500
    }

    # ─── Service consumers ──────────────────────────────────────────────
    # One @matcher + handle block per registered service.

    @svc_fred_zulip_bot_worker header Authorization "Bearer {env.FRED_MCP_TOKEN_FRED_ZULIP_BOT_WORKER}"
    handle @svc_fred_zulip_bot_worker {
        reverse_proxy 127.0.0.1:5000 {
            header_up X-Service fred-zulip-bot-worker
        }
    }

    # ─── Legacy shared bearer (humans, transition period) ──────────────
    # Remove this block once all human consumers migrate to OIDC.
    @authorized header Authorization "Bearer {env.FRED_MCP_TOKEN}"
    handle @authorized {
        reverse_proxy 127.0.0.1:5000
    }

    # ─── Default: OIDC via forward_auth to tokeninfo sidecar ───────────
    # Caddy sends the request headers to the sidecar's /verify endpoint.
    # On 2xx: copies X-Auth-* headers and proxies to toolbox.
    # On 4xx: returns the sidecar's 401 + WWW-Authenticate to the client.
    handle {
        forward_auth 127.0.0.1:5500 {
            uri /verify
            copy_headers X-Auth-Email X-Auth-Sub X-Auth-Hd
        }
        reverse_proxy 127.0.0.1:5000
    }
}
